{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug DevUI",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/.venv/bin/python",
            "program": "${workspaceFolder}/.venv/bin/devui",
            "args": [
                "${workspaceFolder}/src/progressive_exposure/agents",
                "--no-open",
                "--port",
                "8080"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "pythonArgs": [
                "-Xfrozen_modules=off"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        },
        {
            "name": "Debug CLI",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/.venv/bin/python",
            "module": "progressive_exposure",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "pythonArgs": [
                "-Xfrozen_modules=off"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        },
        {
            "name": "Stock Quotes API (:8001)",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/.venv/bin/python",
            "module": "uvicorn",
            "args": [
                "progressive_exposure.financial_apis.stocks_app:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8001",
                "--reload"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "pythonArgs": [
                "-Xfrozen_modules=off"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        },
        {
            "name": "Portfolio Holdings API (:8002)",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/.venv/bin/python",
            "module": "uvicorn",
            "args": [
                "progressive_exposure.financial_apis.portfolio_app:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8002",
                "--reload"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "pythonArgs": [
                "-Xfrozen_modules=off"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        },
        {
            "name": "Market Indices API (:8003)",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/.venv/bin/python",
            "module": "uvicorn",
            "args": [
                "progressive_exposure.financial_apis.indices_app:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8003",
                "--reload"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "pythonArgs": [
                "-Xfrozen_modules=off"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        },
        {
            "name": "All Financial APIs (:8000)",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/.venv/bin/python",
            "module": "uvicorn",
            "args": [
                "progressive_exposure.financial_apis.app:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8000",
                "--reload"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "pythonArgs": [
                "-Xfrozen_modules=off"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        }
    ],
    "compounds": [
        {
            "name": "All APIs + Dev UI",
            "configurations": [
                "All Financial APIs (:8000)",
                "Debug DevUI"
            ],
            "stopAll": true
        }
    ]
}